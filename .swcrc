{
  "$schema": "https://json.schemastore.org/swcrc.schema.json",
  "env": {
    "targets": {
      "node": "20"
    }
  },
  "jsc": {
    "parser": {
      "syntax": "typescript",
      "decorators": true,
      "decoratorsBeforeExport": true,
      "dynamicImport": true,
      "classProperties": true,
      "classPrivateProperties": true,
      "classPrivateMethods": true,
      "privateMethod": true,
      "topLevelAwait": true
    },
    "target": "es2021",
    "baseUrl": "./",
    "paths": {
      "@/*": ["src/*"],
      "@modules/*": ["src/modules/*"],
      "@common/*": ["src/common/*"],
      "@database/*": ["src/database/*"],
      "@config/*": ["src/config/*"],
      "@types/*": ["src/types/*"]
    },
    "transform": {
      "decoratorMetadata": true,
      "legacyDecorator": true
    },
    "externalHelpers": true,
    "keepClassNames": true
  },
  "module": {
    "type": "commonjs",
    "ignoreDynamic": false,
    "noInterop": false,
    "strict": false,
    "strictMode": true,
    "lazy": false
  },
  "minify": false,
  "sourceMaps": true,
  "inlineSourcesContent": true,
  "exclude": [
    "node_modules",
    "dist",
    "coverage",
    "test",
    "logs",
    "keys",
    "src/metadata.ts",
    "**/*spec.ts",
    "**/*test.ts",
    "**/*.d.ts"
  ]
}

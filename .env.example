################################################################################
# ENVIRONMENT VARIABLES - TEMPLATE
# Copy this file to .env and fill in with your values
# Use NODE_ENV to control which environment is active:
#   - development: Local development with debug logging
#   - staging: Staging environment for testing
#   - production: Production environment with strict logging
################################################################################

# Node Environment (development | staging | production)
# This controls which configuration is used by the application
NODE_ENV=development

################################################################################
# DATABASE CONFIGURATION
################################################################################
# PostgreSQL connection string (NeonDB or standard PostgreSQL)
# Format: postgresql://user:password@host:port/dbname?options
DATABASE_URL=postgresql://user:password@localhost:5432/test_db?sslmode=disable

################################################################################
# SERVER CONFIGURATION
################################################################################
# Server port (default: 3000)
PORT=3000

# Server host (bind address)
HOST=0.0.0.0

################################################################################
# LOGGING CONFIGURATION
################################################################################
# Log level: error, warn, log, debug, verbose
# - error: Only errors
# - warn: Warnings and errors
# - log: Info, warnings, and errors
# - debug: Debug, info, warnings, errors
# - verbose: All logs including stack traces
LOG_LEVEL=debug

# Log format: pretty, json
# - pretty: Human-readable format (development)
# - json: JSON format (production)
LOG_FORMAT=pretty

################################################################################
# CORS CONFIGURATION
################################################################################
# Comma-separated list of allowed origins
# For development: http://localhost:3000
# For production: https://yourdomain.com
CORS_ORIGIN=http://localhost:3000

# Allow credentials in CORS requests
CORS_CREDENTIALS=true

################################################################################
# API CONFIGURATION
################################################################################
# API version for versioning endpoints
API_VERSION=v1

# API prefix for all routes
API_PREFIX=/api

################################################################################
# AUTHENTICATION & SECURITY
# ⚠️ MUST be changed in production!
################################################################################
# JWT signing secret (minimum 32 characters recommended)
JWT_SECRET=your-secret-key-here-change-in-production-min-32-chars

# JWT token expiration time
JWT_EXPIRATION=24h

# JWT refresh token secret
JWT_REFRESH_SECRET=your-refresh-secret-here-change-in-production-min-32-chars

# JWT refresh token expiration
JWT_REFRESH_EXPIRATION=7d

################################################################################
# RATE LIMITING (Optional)
################################################################################
# Time window for rate limiting in milliseconds (default: 1 minute)
RATE_LIMIT_WINDOW_MS=60000

# Maximum requests per window (default: 100)
RATE_LIMIT_MAX_REQUESTS=100

################################################################################
# CACHE CONFIGURATION (Optional)
################################################################################
# Cache time-to-live in seconds
CACHE_TTL=300

# Maximum number of items in cache
CACHE_MAX_SIZE=100

################################################################################
# FILE UPLOAD CONFIGURATION (Optional)
################################################################################
# Maximum file size in bytes (5MB = 5242880)
MAX_FILE_SIZE=5242880

# Upload directory
UPLOAD_DIR=./uploads

################################################################################
# EMAIL SERVICE CONFIGURATION (Optional - for future use)
################################################################################
# SMTP host for sending emails
MAIL_HOST=smtp.gmail.com

# SMTP port
MAIL_PORT=587

# SMTP authentication username
MAIL_USER=your-email@gmail.com

# SMTP authentication password
MAIL_PASSWORD=your-app-password

# Email sender address
MAIL_FROM=noreply@example.com

################################################################################
# AWS S3 CONFIGURATION (Optional - for future use)
################################################################################
# AWS region
AWS_REGION=us-east-1

# AWS IAM access key ID
AWS_ACCESS_KEY_ID=

# AWS IAM secret access key
AWS_SECRET_ACCESS_KEY=

# S3 bucket name
AWS_S3_BUCKET=

################################################################################
# PAYMENT CONFIGURATION - Stripe (Optional - for future use)
################################################################################
# Stripe secret API key (starts with sk_)
STRIPE_SECRET_KEY=

# Stripe public API key (starts with pk_)
STRIPE_PUBLIC_KEY=

################################################################################
# OAuth2 PROVIDER CONFIGURATION (Optional - for future use)
################################################################################
# Google OAuth2
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth2
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Microsoft OAuth2
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

################################################################################
# MONITORING & OBSERVABILITY (Optional - for future use)
################################################################################
# Sentry error tracking DSN
SENTRY_DSN=

# Sentry environment name
SENTRY_ENVIRONMENT=development

# Sentry trace sample rate (0-1, lower values = fewer traces)
SENTRY_TRACE_SAMPLE_RATE=0.1

################################################################################
# ENVIRONMENT-SPECIFIC NOTES
################################################################################
# DEVELOPMENT:
#   - LOG_LEVEL: debug or verbose
#   - LOG_FORMAT: pretty
#   - DATABASE_URL: local or dev database
#   - JWT_SECRET: any string (not used in production)
#   - CORS_ORIGIN: http://localhost:*
#   - Credentials: true
#
# STAGING:
#   - LOG_LEVEL: log or debug
#   - LOG_FORMAT: json
#   - DATABASE_URL: staging database
#   - JWT_SECRET: secure random string (minimum 32 chars)
#   - CORS_ORIGIN: staging domain
#   - Credentials: conditional
#
# PRODUCTION:
#   - LOG_LEVEL: error or warn
#   - LOG_FORMAT: json
#   - DATABASE_URL: production database (high availability)
#   - JWT_SECRET: VERY secure random string (minimum 32 chars)
#   - CORS_ORIGIN: production domain only
#   - Credentials: false
#   - All secrets: rotate regularly
#   - Enable monitoring and alerting
#
################################################################################

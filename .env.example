################################################################################
# ENVIRONMENT CONFIGURATION - Development
# This file is loaded by dotenv. For production, use .env.production
################################################################################

# Node Environment (development | staging | production)
NODE_ENV=development

################################################################################
# DATABASE CONFIGURATION
################################################################################
DATABASE_URL=postgresql://neondb_owner:npg_SQjd0ak7mIuG@ep-quiet-band-am8tgxch-pooler.c-5.us-east-1.aws.neon.tech/CIAP?sslmode=require&channel_binding=require

################################################################################
# SERVER CONFIGURATION
################################################################################
PORT=3000
HOST=localhost

################################################################################
# LOGGING CONFIGURATION
# Levels: error, warn, log, debug, verbose
################################################################################
LOG_LEVEL=debug
LOG_FORMAT=pretty

################################################################################
# CORS CONFIGURATION
################################################################################
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

################################################################################
# API CONFIGURATION
################################################################################
API_VERSION=v1
API_PREFIX=/api

################################################################################
# AUTHENTICATION & SECURITY
################################################################################
JWT_SECRET=dev-secret-key-change-in-production
JWT_EXPIRATION=24h
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production
JWT_REFRESH_EXPIRATION=7d

################################################################################
# RATE LIMITING (Optional - for future use)
################################################################################
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

################################################################################
# CACHE CONFIGURATION (Optional - for future use)
################################################################################
CACHE_TTL=300
CACHE_MAX_SIZE=100

################################################################################
# FILE UPLOAD CONFIGURATION (Optional - for future use)
################################################################################
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads

################################################################################
# THIRD-PARTY SERVICES (Optional - preseed for future integrations)
################################################################################
# Email Service
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=noreply@example.com


# OAuth2 Providers (Optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

################################################################################
# MONITORING & OBSERVABILITY (Optional - for future use)
################################################################################
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACE_SAMPLE_RATE=0.1
